{
  "name": "43-industries",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "node scripts/prepare-build.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint app components lib prisma scripts tests --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "release": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1",
    "rewards:api": "node services/rewards-api/server.js",
    "rewards:issue-token": "node services/rewards-api/issue-token.js",
    "rewards:blackhole-issuer": "node services/rewards-api/blackhole-issuer.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@clerk/nextjs": "^7.0.12",
    "@prisma/client": "^6.7.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xrpl": "^4.4.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prettier": "^3.6.2",
    "prisma": "^6.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
